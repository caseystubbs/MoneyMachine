generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  REFUND
  FEE
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

enum SourceAccount {
  STRIPE
  PAYPAL
  AMEX
  MANUAL
}

enum BusinessUnit {
  PUBLISHING
  MEDIA
  COMBINED
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules        CategoryRule[]
  transactions Transaction[]
}

model CategoryRule {
  id         String   @id @default(cuid())
  contains   String
  categoryId String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id])

  @@index([contains])
  @@index([categoryId])
}

model Transaction {
  id           String          @id @default(cuid())
  date         DateTime
  amount       Decimal         // ✅ no @db.Numeric annotation
  description  String
  vendor       String?
  currency     String          @default("USD")

  type         TransactionType
  source       SourceAccount
  businessUnit BusinessUnit    @default(COMBINED)

  monthKey     String          // "YYYY-MM"
  externalId   String?
  raw          Json?

  categoryId   String?
  category     Category?       @relation(fields: [categoryId], references: [id])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([monthKey])
  @@index([type])
  @@index([source])
  @@index([businessUnit])
  @@index([externalId])
  @@index([categoryId])
}

model MonthClose {
  id       String   @id @default(cuid())
  monthKey String   @unique
  closedAt DateTime @default(now())
  notes    String?
}