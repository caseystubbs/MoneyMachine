generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum TransactionType {
  INCOME
  REFUND
  FEE
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

enum SourceAccount {
  STRIPE
  PAYPAL
  PLAID
  AMEX
  YOUTUBE
  SUBSTACK
  MANUAL
}

enum BusinessUnit {
  PUBLISHING
  MEDIA
  COMBINED
}

// ─── Categories ──────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  group     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rules        CategoryRule[]
  transactions Transaction[]
}

model CategoryRule {
  id         String   @id @default(cuid())
  contains   String
  categoryId String
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id])

  @@index([contains])
  @@index([categoryId])
}

// ─── Categorization Rules Engine ─────────────────────────

model CategorizationRule {
  id            String   @id @default(cuid())
  priority      Int      @default(100)
  sourceSystem  String?  // STRIPE, PAYPAL, PLAID, AMEX, null=any
  matchField    String   @default("description") // description, vendor, counterparty
  matchType     String   @default("contains")    // exact, contains, regex
  matchValue    String
  category      String   // Revenue, Expense, Fee, Transfer, etc.
  subcategory   String?  // Software, Contractor, Processing, etc.
  subtype       String?  // Hosting, AI, Design, YouTube, etc.
  txType        String?  // override transaction type: INCOME, EXPENSE, FEE, TRANSFER
  isIgnored     Boolean  @default(false)
  isOneTime     Boolean  @default(false)
  isBusinessRelevant Boolean @default(true)
  notes         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active])
  @@index([priority])
  @@index([matchValue])
}

// ─── Transactions ────────────────────────────────────────

model Transaction {
  id           String          @id @default(cuid())
  date         DateTime
  amount       Decimal
  description  String
  vendor       String?
  currency     String          @default("USD")

  type         TransactionType
  source       SourceAccount
  businessUnit BusinessUnit    @default(COMBINED)

  monthKey     String          // "YYYY-MM"
  externalId   String?         @unique
  raw          Json?

  // Categorization fields
  categoryId   String?
  category     Category?       @relation(fields: [categoryId], references: [id])
  subcategory  String?
  subtype      String?
  isIgnored    Boolean         @default(false)
  isOneTime    Boolean         @default(false)
  isBusinessRelevant Boolean   @default(true)
  ruleIdApplied String?        // which CategorizationRule was applied
  manualOverride Boolean       @default(false) // true if human reclassified

  plaidAccountId String?
  plaidAccount   PlaidAccount?  @relation(fields: [plaidAccountId], references: [id])

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([monthKey])
  @@index([type])
  @@index([source])
  @@index([businessUnit])
  @@index([categoryId])
  @@index([plaidAccountId])
  @@index([date])
  @@index([isIgnored])
  @@index([subcategory])
}

// ─── Plaid ───────────────────────────────────────────────

model PlaidItem {
  id              String   @id @default(cuid())
  institutionId   String?
  institutionName String?
  accessToken     String   // encrypted in production
  itemId          String   @unique
  cursor          String?  // Plaid sync cursor for incremental updates
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  accounts PlaidAccount[]
}

model PlaidAccount {
  id             String   @id @default(cuid())
  plaidAccountId String   @unique
  name           String
  officialName   String?
  type           String   // checking, savings, credit, etc.
  subtype        String?
  mask           String?  // last 4 digits

  currentBalance  Decimal?
  availableBalance Decimal?
  balanceUpdatedAt DateTime?

  plaidItemId String
  plaidItem   PlaidItem @relation(fields: [plaidItemId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plaidItemId])
}

// ─── Sync Tracking ───────────────────────────────────────

model SyncLog {
  id        String        @id @default(cuid())
  source    SourceAccount
  status    String        // "success" | "error"
  message   String?
  txAdded   Int           @default(0)
  txUpdated Int           @default(0)
  duration  Int?          // milliseconds
  createdAt DateTime      @default(now())

  @@index([source])
  @@index([createdAt])
}

// ─── Month Close ─────────────────────────────────────────

model MonthClose {
  id       String   @id @default(cuid())
  monthKey String   @unique
  closedAt DateTime @default(now())
  notes    String?
}

// ─── Monthly Reports ─────────────────────────────────────

model MonthlyReport {
  id          String   @id @default(cuid())
  monthKey    String   @unique
  reportJson  Json
  generatedAt DateTime @default(now())
  status      String   @default("draft") // draft, final
}